@page "/WebChat"
@inject IJSRuntime JSRuntime
@inject AuthStateProvider AuthStateProvider
@using Client.Services
@using Microsoft.AspNetCore.SignalR.Client

<div class="chat-container">
    <div class="sidebar">
        <div class="app-title">
            <h1>BlazorChat</h1>
        </div>
        <div class="user-profile">
            <div class="avatar">
                <img src="/api/placeholder/40/40" alt="Profile" />
            </div>
            <div class="user-name">@_nickname</div>
        </div>
        <div class="contact-list">
            <h2>Kontakte</h2>
            @foreach (var contact in _friends)
            {
                <div class="contact-item @(SelectedContact == contact ? "selected" : "")" @onclick="() => SelectContact(contact)">
                    <div class="contact-avatar">
                        <img src="/api/placeholder/32/32" alt="@contact" />
                    </div>
                    <div class="contact-info">
                        <div class="contact-name">@contact</div>
                        <div class="contact-status">@(OnlineContacts.Contains(contact) ? "Online" : "Offline")</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="chat-main">
        <div class="chat-header">
            @if (!string.IsNullOrEmpty(SelectedContact))
            {
                <div class="selected-contact">
                    <div class="contact-avatar">
                        <img src="/api/placeholder/40/40" alt="@SelectedContact" />
                    </div>
                    <div class="contact-info">
                        <div class="contact-name">@SelectedContact</div>
                        <div class="contact-status">@(OnlineContacts.Contains(SelectedContact) ? "Online" : "Offline")</div>
                    </div>
                </div>
            }
            else
            {
                <div class="no-selection">Wähle einen Kontakt aus, um zu chatten</div>
            }
        </div>

        <div class="messages-container" id="messagesContainer">
            @if (!string.IsNullOrEmpty(SelectedContact))
            {
                @foreach (var message in GetMessagesForCurrentContact())
                {
                    <div class="message @(message.IsFromCurrentUser ? "sent" : "received")">
                        <div class="message-content">
                            <div class="message-text">@message.Text</div>
                            <div class="message-time">@message.Timestamp.ToString("HH:mm")</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-chat">
                    <div class="empty-chat-icon">💬</div>
                    <div class="empty-chat-text">Wähle einen Kontakt aus, um mit dem Chatten zu beginnen</div>
                </div>
            }
        </div>

        <div class="message-input-container">
            @if (!string.IsNullOrEmpty(SelectedContact))
            {
                <input
                    type="text"
                    class="message-input"
                    placeholder="Nachricht eingeben..."
                    @bind="_message"
                    @bind:event="oninput"
                    @onkeypress="HandleKeyPress" />
                <button class="send-button" @onclick="SendMessage">
                    <span>Senden</span>
                </button>
            }
        </div>
    </div>
</div>

<style>
