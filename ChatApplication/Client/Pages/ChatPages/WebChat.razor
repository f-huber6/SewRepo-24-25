</style>

@code {
    private HubConnection? _hubConnection;
    private string[] _friends = { "Flotschi123", "dloadinq" };
    private string _nickname = "";
    private string _message = "";
    private string _newRoomName = "";
    private string? _currentRoom = null;
    private List<string> _chatRooms = new();
    private List<string> _usersInRoom = new();
    private List<string> OnlineContacts = new List<string> { "Flotschi123" };
    private string SelectedContact { get; set; } = "";
    private Dictionary<string, List<ChatMessage>> AllMessages { get; set; } = new Dictionary<string, List<ChatMessage>>();

    protected override async Task OnInitializedAsync()
    {
        // Initialize message dictionary for each friend
        foreach (var friend in _friends)
        {
            AllMessages[friend] = new List<ChatMessage>();
        }

        // Select first contact by default
        if (_friends.Length > 0)
        {
            SelectedContact = _friends[0];
        }

        _hubConnection = new HubConnectionBuilder()
            .WithUrl("http://localhost:5205/chat")
            .WithAutomaticReconnect()
            .Build();
        
        _hubConnection.On<string, List<string>>("RegistrationSucceeded", (nickname, rooms) =>
        {
            _nickname = nickname;
            _chatRooms = rooms;
            StateHasChanged();
        });

        _hubConnection.On<string>("ChatRoomCreated", room =>
        {
            if (!_chatRooms.Contains(room))
            {
                _chatRooms.Add(room);
                StateHasChanged();
            }
        });

        _hubConnection.On<List<string>>("UpdateUserList", users =>
        {
            _usersInRoom = users;
            OnlineContacts = users;
            StateHasChanged();
        });

        _hubConnection.On<string, string>("ReceiveMessage", (user, msg) =>
        {
            // Add received message to the appropriate contact
            if (user != _nickname && _friends.Contains(user))
            {
                AllMessages[user].Add(new ChatMessage 
                { 
                    Text = msg, 
                    IsFromCurrentUser = false, 
                    Timestamp = DateTime.Now 
                });
                StateHasChanged();
                ScrollToBottom();
            }
        });

        _hubConnection.On<string>("UserJoined", user =>
        {
            if (!OnlineContacts.Contains(user))
            {
                OnlineContacts.Add(user);
            }
            StateHasChanged();
        });

        _hubConnection.On<string>("UserLeft", user =>
        {
            OnlineContacts.Remove(user);
            StateHasChanged();
        });

        await _hubConnection.StartAsync();

        var username = await AuthStateProvider.GetUserName();

        if (!string.IsNullOrEmpty(username))
        {
            _nickname = username;
            await _hubConnection.InvokeAsync("RegisterUser", username);
        }
    }

    private async Task RegisterUser()
    {
        await _hubConnection!.InvokeAsync("RegisterUser", _nickname);
    }

    private void SelectContact(string contact)
    {
        SelectedContact = contact;
        StateHasChanged();
        ScrollToBottom();
    }

    private List<ChatMessage> GetMessagesForCurrentContact()
    {
        if (string.IsNullOrEmpty(SelectedContact) || !AllMessages.ContainsKey(SelectedContact))
        {
            return new List<ChatMessage>();
        }
        
        return AllMessages[SelectedContact];
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_message) || string.IsNullOrEmpty(SelectedContact))
        {
            return;
        }

        // Add message to local chat history
        if (!AllMessages.ContainsKey(SelectedContact))
        {
            AllMessages[SelectedContact] = new List<ChatMessage>();
        }
        
        AllMessages[SelectedContact].Add(new ChatMessage
        {
            Text = _message,
            IsFromCurrentUser = true,
            Timestamp = DateTime.Now
        });

        // Send message via SignalR
        if (_hubConnection != null && _hubConnection.State == HubConnectionState.Connected)
        {
            try {
                await _hubConnection.InvokeAsync("SendDirectMessage", SelectedContact, _message);
            }
            catch (Exception ex) {
                // Fallback to standard message if direct messaging isn't implemented
                if (_currentRoom != null) {
                    await _hubConnection.InvokeAsync("SendMessage", _currentRoom, _message);
                }
            }
        }
        
        _message = "";
        StateHasChanged();
        await ScrollToBottom();
    }

    private async Task JoinChatRoom(string room)
    {
        if (_currentRoom != null)
        {
            await _hubConnection!.InvokeAsync("LeaveChatRoom", _currentRoom);
        }

        _currentRoom = room;
        await _hubConnection!.InvokeAsync("JoinChatRoom", room);
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }
    
    private async Task ScrollToBottom()
    {
        await Task.Delay(50); // Kurze Verzögerung, um sicherzustellen, dass die UI aktualisiert wurde
        await JSRuntime.InvokeVoidAsync("scrollToBottom", "messagesContainer");
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("eval", @"
                window.scrollToBottom = function(id) {
                    var element = document.getElementById(id);
                    if (element) {
                        element.scrollTop = element.scrollHeight;
                    }
                }
            ");
            
            await ScrollToBottom();
        }
    }

    public class ChatMessage
    {
        public string Text { get; set; }
        public bool IsFromCurrentUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
}